{
  "tests": [
    {
      "name": "OPTIONS CORS",
      "method": "OPTIONS",
      "path": "/",
      "expectedStatus": 200
    },
    {
      "name": "GET /settings без group_id — 400",
      "method": "GET",
      "path": "/",
      "expectedStatus": 400,
      "expectedBody": {"error": "group_id required"},
      "bodyMatcher": "partial"
    },
    {
      "name": "GET /settings несуществующая группа — 404",
      "method": "GET",
      "path": "/?group_id=nonexistent_xyz_123",
      "expectedStatus": 404,
      "expectedBody": {"connected": false},
      "bodyMatcher": "partial"
    },
    {
      "name": "GET /violations без group_id — 400",
      "method": "GET",
      "path": "/violations",
      "expectedStatus": 400,
      "expectedBody": {"error": "group_id required"},
      "bodyMatcher": "partial"
    },
    {
      "name": "GET /violations для группы — 200",
      "method": "GET",
      "path": "/violations?group_id=test_group_123&days=7",
      "expectedStatus": 200,
      "expectedBody": {"total": 0},
      "bodyMatcher": "partial"
    },
    {
      "name": "GET /lists без group_id — 400",
      "method": "GET",
      "path": "/lists",
      "expectedStatus": 400,
      "expectedBody": {"error": "group_id required"},
      "bodyMatcher": "partial"
    },
    {
      "name": "GET /lists для группы — 200",
      "method": "GET",
      "path": "/lists?group_id=test_group_123",
      "expectedStatus": 200,
      "expectedBody": {"whitelist": [], "blacklist": []},
      "bodyMatcher": "partial"
    },
    {
      "name": "POST connect без параметров — 400",
      "method": "POST",
      "path": "/",
      "body": {"action": "connect", "token": "", "group_id": ""},
      "expectedStatus": 400,
      "expectedBody": {"error": "token and group_id required"},
      "bodyMatcher": "partial"
    },
    {
      "name": "POST set_trial_days без user_id — 400",
      "method": "POST",
      "path": "/",
      "body": {"action": "set_trial_days", "days": 14},
      "expectedStatus": 400,
      "expectedBody": {"error": "user_id, days required"},
      "bodyMatcher": "partial"
    },
    {
      "name": "POST set_trial_days некорректное число — 400",
      "method": "POST",
      "path": "/",
      "body": {"action": "set_trial_days", "user_id": 1, "session_token": "bad", "days": 0},
      "expectedStatus": 400,
      "expectedBody": {"error": "days must be 1–365"},
      "bodyMatcher": "partial"
    },
    {
      "name": "POST set_trial_days без прав — 403",
      "method": "POST",
      "path": "/",
      "body": {"action": "set_trial_days", "user_id": 1, "session_token": "fakefakefake", "days": 14},
      "expectedStatus": 403,
      "expectedBody": {"error": "Доступ запрещён"},
      "bodyMatcher": "partial"
    },
    {
      "name": "GET /moderation без chat_id — 400",
      "method": "GET",
      "path": "/moderation",
      "expectedStatus": 400,
      "expectedBody": {"error": "chat_id required"},
      "bodyMatcher": "partial"
    },
    {
      "name": "GET /moderation несуществующий чат — 200 defaults",
      "method": "GET",
      "path": "/moderation?chat_id=999999999",
      "expectedStatus": 200,
      "expectedBody": {"moderation_enabled": false},
      "bodyMatcher": "partial"
    },
    {
      "name": "GET /banned-words без user_id — 400",
      "method": "GET",
      "path": "/banned-words",
      "expectedStatus": 400,
      "expectedBody": {"error": "user_id required"},
      "bodyMatcher": "partial"
    },
    {
      "name": "GET /moderation-log без user_id — 400",
      "method": "GET",
      "path": "/moderation-log",
      "expectedStatus": 400,
      "expectedBody": {"error": "user_id required"},
      "bodyMatcher": "partial"
    },
    {
      "name": "GET /filter-settings без user_id — 400",
      "method": "GET",
      "path": "/filter-settings",
      "expectedStatus": 400,
      "expectedBody": {"error": "user_id required"},
      "bodyMatcher": "partial"
    },
    {
      "name": "POST /webhook — пустое событие",
      "method": "POST",
      "path": "/webhook",
      "body": {"update_type": "unknown"},
      "expectedStatus": 200,
      "expectedBody": {"ok": true},
      "bodyMatcher": "partial"
    }
  ]
}