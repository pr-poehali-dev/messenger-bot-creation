{
  "tests": [
    {
      "name": "OPTIONS CORS",
      "method": "OPTIONS",
      "path": "/",
      "expectedStatus": 200
    },
    {
      "name": "GET violations без group_id — 400",
      "method": "GET",
      "path": "/violations",
      "expectedStatus": 400,
      "expectedBody": {"error": "group_id required"},
      "bodyMatcher": "partial"
    },
    {
      "name": "GET violations для группы — 200",
      "method": "GET",
      "path": "/violations?group_id=test_group_123&days=7",
      "expectedStatus": 200,
      "expectedBody": {"total": 0, "by_type": [], "top_violators": [], "by_day": []},
      "bodyMatcher": "partial"
    },
    {
      "name": "GET lists без group_id — 400",
      "method": "GET",
      "path": "/lists",
      "expectedStatus": 400,
      "expectedBody": {"error": "group_id required"},
      "bodyMatcher": "partial"
    },
    {
      "name": "GET lists для группы — 200",
      "method": "GET",
      "path": "/lists?group_id=test_group_123",
      "expectedStatus": 200,
      "expectedBody": {"whitelist": [], "blacklist": []},
      "bodyMatcher": "partial"
    }
  ]
}
